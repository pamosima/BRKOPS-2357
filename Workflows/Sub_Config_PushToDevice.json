      {
        "unique_name": "definition_activity_02TVD48RBHHDU4L0BwiNtt1LZGBxoyKhv5q",
        "name": "Execute Python Script",
        "title": "Build SSH Command",
        "type": "python3.script",
        "base_type": "activity",
        "properties": {
          "action_timeout": 180,
          "continue_on_failure": false,
          "description": "Build the SSH command to execute push_config.py on the Linux host",
          "display_name": "Build SSH Command",
          "script": "import sys\nimport json\n\nscripts_path = sys.argv[1]\ndevice_ip = sys.argv[2]\ndevice_type = sys.argv[3]\nconfig_commands = sys.argv[4]\n\nif not scripts_path or not scripts_path.strip():\n    raise ValueError('Scripts Path is required but empty')\n\nif not device_ip or not device_ip.strip():\n    raise ValueError('Device IP is required but empty')\n\nif not device_type or not device_type.strip():\n    raise ValueError('Device Type is required but empty - check if platform is set in NetBox')\n\nconfig_escaped = config_commands.replace(\"'\", \"'\\\"'\\\"'\")\n\nssh_cmd = f'''cd {scripts_path} && source venv/bin/activate && export $(grep -v '^#' .env | xargs) && python3 push_config.py {device_ip} {device_type} '{config_escaped}' '''\n\nprint(f'Command built for device: {device_ip} ({device_type})')\n",
          "script_arguments": [
            "$workflow.definition_workflow_02TVD46Y5S41S4rVjSxmBQ8x5ZNRdHEaA4e.static.variable_workflow_02TVD46YSMMOA0pAHOoANI34QqMEUJILKRm$",
            "$workflow.definition_workflow_02TVD46Y5S41S4rVjSxmBQ8x5ZNRdHEaA4e.local.variable_workflow_02TVD46YSKFG26VOnhJQN2ScfsSjms2778q$",
            "$workflow.definition_workflow_02TVD46Y5S41S4rVjSxmBQ8x5ZNRdHEaA4e.local.variable_workflow_02TVD46YSLFIW2VIvt7HZXc2DfwB5zTwLB9$",
            "$workflow.definition_workflow_02TVD46Y5S41S4rVjSxmBQ8x5ZNRdHEaA4e.local.variable_workflow_02TVD46YSLL220ACcUSRCWfHtNPMOu0oBYN$"
          ],
          "script_queries": [
            {
              "script_query": "ssh_cmd",
              "script_query_name": "SSH Command",
              "script_query_type": "string"
            }
          ],
          "skip_execution": false
        },
        "object_type": "definition_activity"
      },
      {
        "unique_name": "definition_activity_02TVD48VCL66L5Z3W1cAaHCnhGF4w4vcHlR",
