      {
        "unique_name": "definition_activity_02TVD491IVVJL1tcxrWswb7N0cPMFMp8DEX",
        "name": "Execute Python Script",
        "title": "Parse Push Result",
        "type": "python3.script",
        "base_type": "activity",
        "properties": {
          "action_timeout": 180,
          "continue_on_failure": false,
          "description": "Parse the output from push_config.py to determine success/failure",
          "display_name": "Parse Push Result",
          "script": "import sys\nimport json\nimport re\n\nssh_output = sys.argv[1]\nssh_succeeded = sys.argv[2].lower() == 'true' if len(sys.argv) > 2 else False\n\ntry:\n    if not ssh_succeeded:\n        success = False\n        summary = f'SSH command failed. Output: {ssh_output[:300]}'\n    else:\n        json_match = re.search(r'\\{[^{}]*\"status\"[^{}]*\\}', ssh_output, re.DOTALL)\n        \n        if json_match:\n            result = json.loads(json_match.group())\n            success = result.get('status') == 'success'\n            summary = f\"Status: {result.get('status')}\\nDevice: {result.get('device')}\\nCommands sent: {result.get('commands_sent', 0)}\"\n            if result.get('error'):\n                summary += f\"\\nError: {result.get('error')}\"\n        else:\n            success = 'success' in ssh_output.lower() and 'failed' not in ssh_output.lower()\n            summary = ssh_output[:500] if len(ssh_output) > 500 else ssh_output\n        \nexcept Exception as e:\n    success = False\n    summary = f'Error parsing result: {str(e)}\\nRaw output: {ssh_output[:200]}'\n\nprint(f'Success: {success}')\nprint(f'Summary: {summary}')\n",
          "script_arguments": [
            "$activity.definition_activity_02TVD48XVZKCO6iJY0WaEnYwPOBLljWJkkQ.output.response_body$",
            "$activity.definition_activity_02TVD48XVZKCO6iJY0WaEnYwPOBLljWJkkQ.output.succeeded$"
          ],
          "script_queries": [
            {
              "script_query": "success",
              "script_query_name": "Success",
              "script_query_type": "boolean"
            },
            {
              "script_query": "summary",
              "script_query_name": "Summary",
              "script_query_type": "string"
            }
          ],
          "skip_execution": false
        },
        "object_type": "definition_activity"
      },
