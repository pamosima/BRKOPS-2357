    "properties": {
      "atomic": {
        "is_atomic": false
      },
      "delete_workflow_instance": false,
      "description": "Pushes rendered configuration from NetBox to a network device via SSH.\n\nWorkflow:\n1. Fetches devices from NetBox for dropdown selection\n2. Prompts user to select device\n3. Calls NetBox render-config API to get rendered configuration\n4. Maps NetBox platform to Netmiko device type\n5. Executes push_config.py on Linux host via SSH\n6. Reports success/failure of configuration push\n\nPrerequisites:\n- Device must exist in NetBox with primary_ip and platform set\n- Device must have a config template assigned (device, role, or platform)\n- Linux host with push_config.py, Python venv, and .env credentials\n- Network connectivity from Linux host to target device\n\nSee: https://netboxlabs.com/docs/netbox/features/configuration-rendering/",
      "display_name": "[Demo] Push Config to Device",
      "runtime_user": {
        "target_default": true
      },
      "target": {
        "execute_on_target_group": true,
        "target_group": {
          "target_group_id": "target_group_02RYFETOZ4HR26rQvvJO9ivmfP7ZMiGrxM4",
          "run_on_all_targets": false,
          "selected_target_types": [
            "netbox.endpoint",
            "terminal.unix_linux_endpoint"
          ],
          "use_criteria": {
            "choose_target_using_algorithm": "choose_first_with_matching_criteria",
            "conditions": [
              {
                "operator": "eq",
                "left_operand": "$targetgroup.target_group_02RYFETOZ4HR26rQvvJO9ivmfP7ZMiGrxM4.common.display_name$",
                "right_operand": "$global.variable_02RYFONKQYBK45LkKmbk7yRyaXFEzcffmwh.global.variable_02RYFONKQYBK45LkKmbk7yRyaXFEzcffmwh$"
              }
            ]
          }
        }
      }
    },
