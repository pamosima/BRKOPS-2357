      {
        "unique_name": "definition_activity_02TVD48XVZKCO6iJY0WaEnYwPOBLljWJkkQ",
        "name": "Execute Linux/Unix SSH Command",
        "title": "Push Config via SSH",
        "type": "terminal.ssh_command",
        "base_type": "activity",
        "properties": {
          "action_timeout": 300,
          "command": "$workflow.definition_workflow_02TVD46Y5S41S4rVjSxmBQ8x5ZNRdHEaA4e.local.variable_workflow_02TVD46YSN6HK21sLcrxBrLYsMNdPs2c46M$",
          "command_timeout": 240,
          "continue_on_failure": true,
          "description": "Execute push_config.py on Linux host to push config to device",
          "display_name": "Push Config via SSH",
          "runtime_user": {
            "target_default": true
          },
          "skip_execution": false,
          "target": {
            "override_workflow_target": true,
