        "actions": [
          {
            "unique_name": "definition_activity_02TVD47COLVG5345WiCDSvU8twWNmlMQZZB",
            "name": "Generic NetBox API Request",
            "title": "Get Devices from NetBox",
            "type": "netbox.invoke_api",
            "base_type": "activity",
            "properties": {
              "_endpoint": "api/dcim/devices/?limit=100&has_primary_ip=true",
              "_method": "GET",
              "action_timeout": 180,
              "continue_on_failure": false,
              "description": "Fetch all devices with primary IP from NetBox for dropdown",
              "display_name": "Get Devices from NetBox",
              "runtime_user": {
                "target_default": true
              },
              "skip_execution": false,
              "target": {
                "override_workflow_target_group_criteria": true,
                "target_group": {
                  "run_on_all_targets": false,
                  "use_criteria": {
                    "choose_target_using_algorithm": "choose_first_with_matching_criteria",
                    "conditions": [
                      {
                        "left_operand": "$targetgroup.target_group_02RYFETOZ4HR26rQvvJO9ivmfP7ZMiGrxM4.common.display_name$",
                        "operator": "eq",
                        "right_operand": "$global.variable_02RYFONKQYBK45LkKmbk7yRyaXFEzcffmwh.global.variable_02RYFONKQYBK45LkKmbk7yRyaXFEzcffmwh$"
                      }
                    ]
                  }
                }
              }
            },
            "object_type": "definition_activity"
          },
          {
            "unique_name": "definition_activity_02TVD47G2CAEA2TXOFf4mNfKKDp1jinQWeS",
            "name": "Execute Python Script",
            "title": "Populate Device Dropdown",
            "type": "python3.script",
            "base_type": "activity",
            "properties": {
              "action_timeout": 180,
              "continue_on_failure": false,
              "display_name": "Populate Device Dropdown",
              "script": "import json\nimport sys\n\nnetbox_response = sys.argv[1] if len(sys.argv) > 1 else '{}'\n\ntry:\n    data = json.loads(netbox_response)\n    devices = data.get('results', [])\n    \n    device_list = []\n    for d in devices:\n        device_id = d.get('id', '')\n        device_name = d.get('name', '')\n        primary_ip = d.get('primary_ip4') or d.get('primary_ip')\n        ip_display = ''\n        if primary_ip:\n            ip_display = primary_ip.get('address', '').split('/')[0]\n        \n        platform = d.get('platform')\n        platform_slug = platform.get('slug', '') if platform else ''\n        platform_name = platform.get('name', 'Unknown') if platform else 'No Platform'\n        \n        # Store device_id, name, ip, and platform_slug for later use\n        device_list.append({\n            'id': str(device_id),\n            'name': f\"{device_name} ({ip_display}) - {platform_name}\",\n            'device_name': device_name,\n            'ip': ip_display,\n            'platform': platform_slug\n        })\n    \n    device_list_json = json.dumps(device_list)\n    print(f'Found {len(device_list)} devices')\nexcept Exception as e:\n    device_list_json = '[]'\n    print(f'Error: {str(e)}')\n",
              "script_arguments": [
                "$activity.definition_activity_02TVD47COLVG5345WiCDSvU8twWNmlMQZZB.output.raw_body$"
              ],
              "script_queries": [
                {
                  "script_query": "device_list_json",
                  "script_query_name": "device_list",
                  "script_query_type": "string"
                }
              ],
              "skip_execution": false
            },
            "object_type": "definition_activity"
          },
          {
            "unique_name": "definition_activity_02TVD47JFH5W94XI42YSllerCGblTDzfMPt",
            "name": "Set Variables",
