      {
        "unique_name": "definition_activity_02TVD48G13IV12SQIibILtdzObtLZlBGNoe",
        "name": "Execute Python Script",
        "title": "Parse Rendered Config",
        "type": "python3.script",
        "base_type": "activity",
        "properties": {
          "action_timeout": 180,
          "continue_on_failure": false,
          "description": "Parse the rendered configuration from NetBox and convert to command list",
          "display_name": "Parse Rendered Config",
          "script": "import sys\nimport json\n\nrendered_response = sys.argv[1]\n\ntry:\n    # Try parsing as JSON (NetBox returns JSON with 'content' field)\n    try:\n        data = json.loads(rendered_response)\n        config_content = data.get('content', rendered_response)\n    except:\n        # If not JSON, use raw response\n        config_content = rendered_response\n    \n    # Split config into lines and filter empty lines\n    config_lines = [line.strip() for line in config_content.split('\\n') if line.strip()]\n    \n    # Remove comment lines (starting with !)\n    config_commands = [line for line in config_lines if not line.startswith('!')]\n    \n    config_json = json.dumps(config_commands)\n    \n    print(f'Parsed {len(config_commands)} config commands')\n    \nexcept Exception as e:\n    print(f'Error: {str(e)}')\n    config_json = '[]'\n",
          "script_arguments": [
            "$workflow.definition_workflow_02TVD46Y5S41S4rVjSxmBQ8x5ZNRdHEaA4e.local.variable_workflow_02TVD46YSL37M3eFu9PzbLdZVacJ7laFc6M$"
          ],
          "script_queries": [
            {
              "script_query": "config_json",
              "script_query_name": "Config JSON",
              "script_query_type": "string"
            }
          ],
          "skip_execution": false
        },
        "object_type": "definition_activity"
      },
      {
        "unique_name": "definition_activity_02TVD48OHZYUY2ey2iBlRw8J7TNVQ8B6KmR",
        "name": "Set Variables",
