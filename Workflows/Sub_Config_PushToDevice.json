              "form_element": "select",
              "form_label": "Device",
              "form_option_label_key": "name",
              "form_option_value_key": "id",
              "form_source_array": "$workflow.definition_workflow_02TVD46Y5S41S4rVjSxmBQ8x5ZNRdHEaA4e.local.variable_workflow_02TVD46YSJL4J5PJMNB5EPbnGKUiCSmmMVE$"
            }
          ],
          "prompt_body": "Please select the target device:\n\n- **Device**: Select the device from NetBox\n- Device must have a config template assigned (to device, role, or platform)\n- Configuration will be rendered using NetBox Config Rendering feature",
          "prompt_title": "Push Config to Device",
          "skip_execution": false,
          "task_owner": "$workflow.definition_workflow_02TVD46Y5S41S4rVjSxmBQ8x5ZNRdHEaA4e.output.started_by$",
          "task_requestor": "$workflow.definition_workflow_02TVD46Y5S41S4rVjSxmBQ8x5ZNRdHEaA4e.output.started_by$",
          "wait_for_prompt_response": true
        },
        "object_type": "definition_activity"
      },
      {
        "unique_name": "definition_activity_02TVD48285PMY50M6pGCXbDVr9IGNh4XD9E",
        "name": "Execute Python Script",
        "title": "Extract Device Info from Prompt",
        "type": "python3.script",
        "base_type": "activity",
        "properties": {
          "action_timeout": 180,
          "continue_on_failure": false,
          "display_name": "Extract Device Info from Prompt",
          "script": "import json\nimport sys\n\nPLATFORM_MAP = {\n    'cisco_ios': 'cisco_ios',\n    'ios': 'cisco_ios',\n    'cisco-ios': 'cisco_ios',\n    'cisco_xe': 'cisco_xe',\n    'ios-xe': 'cisco_xe',\n    'cisco-ios-xe': 'cisco_xe',\n    'iosxe': 'cisco_xe',\n    'cisco_nxos': 'cisco_nxos',\n    'nxos': 'cisco_nxos',\n    'cisco-nxos': 'cisco_nxos',\n    'nexus': 'cisco_nxos',\n    'cisco_xr': 'cisco_xr',\n    'iosxr': 'cisco_xr',\n    'cisco-iosxr': 'cisco_xr',\n    'arista_eos': 'arista_eos',\n    'eos': 'arista_eos',\n    'arista': 'arista_eos',\n    'juniper_junos': 'juniper_junos',\n    'junos': 'juniper_junos',\n    'juniper': 'juniper_junos',\n}\n\nprompt_response = sys.argv[1]\ndevice_list_json = sys.argv[2]\n\ntry:\n    # Try to parse prompt response as JSON (might be full object or just ID)\n    try:\n        prompt_obj = json.loads(prompt_response)\n        if isinstance(prompt_obj, dict):\n            # Prompt returned full object - extract ID directly\n            device_id = str(prompt_obj.get('id', ''))\n            device_name = prompt_obj.get('device_name', prompt_obj.get('name', '').split(' (')[0])\n            device_ip = prompt_obj.get('ip', '')\n            platform_slug = prompt_obj.get('platform', '').lower()\n        else:\n            # Prompt returned just ID\n            device_id = str(prompt_obj)\n            device_name = ''\n            device_ip = ''\n            platform_slug = ''\n    except:\n        # Not JSON - treat as plain ID\n        device_id = str(prompt_response)\n        device_name = ''\n        device_ip = ''\n        platform_slug = ''\n    \n    # If we don't have IP, look it up from the device list\n    if not device_ip and device_list_json:\n        device_list = json.loads(device_list_json)\n        for d in device_list:\n            if str(d.get('id', '')) == device_id:\n                device_name = d.get('device_name', device_name)\n                device_ip = d.get('ip', '')\n                platform_slug = d.get('platform', platform_slug).lower()\n                break\n    \n    # Map platform to Netmiko device type\n    device_type = PLATFORM_MAP.get(platform_slug, 'cisco_ios')\n    \n    print(f'Device ID: {device_id}')\n    print(f'Device Name: {device_name}')\n    print(f'Device IP: {device_ip}')\n    print(f'Platform: {platform_slug} -> Netmiko: {device_type}')\nexcept Exception as e:\n    print(f'Error: {str(e)}')\n    device_id = ''\n    device_name = ''\n    device_ip = ''\n    device_type = 'cisco_ios'\n",
          "script_arguments": [
            "$activity.definition_activity_02TVD47ZK87I82K0PX2wQuizCEiLf0wBXiW.output.prompt_response.Device$",
            "$activity.definition_activity_02TVD47G2CAEA2TXOFf4mNfKKDp1jinQWeS.output.script_queries.device_list$"
          ],
          "script_queries": [
            {
              "script_query": "device_id",
              "script_query_name": "device_id",
              "script_query_type": "string"
            },
            {
              "script_query": "device_name",
              "script_query_name": "device_name",
              "script_query_type": "string"
            },
            {
              "script_query": "device_ip",
              "script_query_name": "device_ip",
              "script_query_type": "string"
            },
            {
              "script_query": "device_type",
              "script_query_name": "device_type",
              "script_query_type": "string"
            }
          ],
          "skip_execution": false
        },
        "object_type": "definition_activity"
      },
